# ── Core ─────────────────────────────────────────────────
PORT=3155
BASE_URL=https://stricklandtechnology.net/trucks

# ── Integrations ─────────────────────────────────────────
ANTHROPIC_KEY=
AYRSHARE_KEY=
SMTP_PASS=
ERIC_EMAIL=

# ── Access control (added for video storage infra) ──────
# Admin dashboard + /admin/* API routes use HTTP Basic auth.
# Leaving ADMIN_PASS empty disables the admin dashboard entirely (503).
ADMIN_USER=admin
ADMIN_PASS=

# The CLIENT_TOKEN gates the /gallery page. Share this URL with the client:
#   https://<host>/gallery?t=<CLIENT_TOKEN>
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CLIENT_TOKEN=
